DATABASE_URL=postgresql://user:password@host/db?sslmode=require
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
PORT=4000
CORS_ORIGIN=http://localhost:5173

RESEND_API_KEY=re_your_api_key
EMAIL_FROM="PursFlow <onboarding@resend.dev>"
REMINDER_SWEEP_INTERVAL_MS=60000

# Générées avec `npx web-push generate-vapid-keys` (une seule fois pour le projet)
VAPID_PUBLIC_KEY=change-me
VAPID_PRIVATE_KEY=change-me
VAPID_SUBJECT=mailto:you@example.com
